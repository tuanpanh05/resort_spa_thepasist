# Base URL of the Spring Boot Backend API
VITE_API_BASE_URL=http://localhost:8080/api

# Firebase Project Credentials (Used for Google OAuth/Firebase Auth)
# Replace with your actual Firebase Web App config
VITE_FIREBASE_API_KEY=your_firebase_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project_id.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
VITE_FIREBASE_APP_ID=1:your_sender_id:web:your_app_hash
VITE_FIREBASE_MEASUREMENT_ID=G-your_measurement_id
