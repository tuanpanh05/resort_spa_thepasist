        <!-- ======================================================= -->
        <!-- LEGEND -->
        <!-- ======================================================= -->
        <mxCell id="legend" value="ADR-001 Key Constraints&#xa;────────────────────&#xa;1. JPA Entities: fu.se.smms.entity ONLY&#xa;2. Controllers = Route + Validate + DTO&#xa;3. Service Layer = Business Logic&#xa;   (@Transactional on all writes)&#xa;4. Frontend: apiRequest() via api.js&#xa;   (never raw fetch/axios in components)&#xa;5. JWT Stateless Auth (no server sessions)&#xa;6. AES-256: Medical / PII data encrypted&#xa;7. CORS: 5173-5179 &lt;--&gt; 8080" style="text;html=1;strokeColor=#4a90d9;fillColor=#0a0a1a;align=left;verticalAlign=top;whiteSpace=wrap;rounded=10;fontColor=#aaccff;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="1480" y="1158" width="260" height="200" as="geometry" />
        </mxCell>

