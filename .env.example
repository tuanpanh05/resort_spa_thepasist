# Ngu Son Resort & Spa - Unified Local Environment Configuration Template
# Copy this file to '.env' in the root directory for local dev run.

# === FRONTEND CONFIGS ===
VITE_API_BASE_URL=http://localhost:8080/api
VITE_FIREBASE_API_KEY=your_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_auth_domain_here
VITE_FIREBASE_PROJECT_ID=your_project_id_here
VITE_FIREBASE_STORAGE_BUCKET=your_storage_bucket_here
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id_here
VITE_FIREBASE_APP_ID=your_app_id_here

# === BACKEND CONFIGS ===
DB_URL=jdbc:sqlserver://localhost:1433;databaseName=ResortSpaDB;encrypt=true;trustServerCertificate=true
DB_USERNAME=sa
DB_PASSWORD=your_password_here
JWT_SECRET=your_jwt_secret_key_must_be_long_and_secure
AES_SECRET_KEY=your_aes_secret_key_32_chars
MAIL_USERNAME=your_gmail_here
MAIL_PASSWORD=your_gmail_app_password_here
MAIL_FROM=your_gmail_here
VNP_TMN_CODE=your_vnpay_tmn_code
VNP_HASH_SECRET=your_vnpay_hash_secret
